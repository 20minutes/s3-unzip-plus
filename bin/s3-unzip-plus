const { cli } = require('cleye')
const pkg = require('../package.json')

async function run() {
  const argv = cli({
    name: 's3-unzip-plus',
    version: pkg.version,
    parameters: ['<bucket-name>', '<filename>', '[target-bucket]', '[target-folder]'],
    flags: {
      deleteOnSuccess: {
        type: Boolean,
        alias: 'd',
        description: 'Delete the zip file on S3 once the decompression has finished',
      },
      copyMetadata: {
        type: Boolean,
        alias: 'm',
        description: 'Copy S3 metadata from zip file to unzipped files',
      },
      verbose: {
        type: Boolean,
        alias: 'v',
        description: 'Show all console logs',
      },
    },
    help: {
      description: pkg.description,
    },
  })

  const bucket = argv._.bucketName
  const file = argv._.filename
  let targetBucket = argv._.targetBucket
  let targetFolder = argv._.targetFolder

  if (!targetBucket) {
    targetBucket = bucket
  }
  if (!targetFolder) {
    targetFolder = ''
  }

  const s3UnzipPlus = require('../lib/index.js')
  await s3UnzipPlus.default({
    bucket,
    file,
    targetBucket,
    targetFolder,
    deleteOnSuccess: argv.flags.deleteOnSuccess ?? false,
    copyMetadata: argv.flags.copyMetadata ?? false,
    verbose: argv.flags.verbose ?? false,
  })
}

run()

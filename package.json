{
  "name": "@20minutes/s3-unzip-plus",
  "version": "1.4.0",
  "description": "Utility for unzipping a compressed (application/zip) file from a S3 bucket's root directory back to the same bucket.",
  "keywords": [
    "s3",
    "zip",
    "archive",
    "unzip"
  ],
  "main": "lib/index.js",
  "module": "esm/index.js",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./esm/index.js",
      "require": "./lib/index.js"
    }
  },
  "bin": {
    "s3-unzip-plus": "bin/s3-unzip-plus"
  },
  "scripts": {
    "build": "yarn build:cjs && yarn build:esm",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:esm": "tsc -p tsconfig.esm.json && node -e \"require('fs').writeFileSync('esm/package.json', '{\\n  \\\"type\\\": \\\"module\\\"\\n}\\n')\"",
    "clean": "rimraf ./dist ./lib ./esm",
    "build-and-test": "yarn clean && yarn build && yarn test",
    "check:package": "yarn build && es-check es2022 \"lib/**/*.js\" \"bin/s3-unzip-plus\" && es-check es2022 \"esm/**/*.js\" --module",
    "test": "jest --silent",
    "test:watch": "jest --watch",
    "lint": "biome check --max-diagnostics=none",
    "lint:fix": "biome check --write --unsafe --max-diagnostics=none",
    "lint:ci": "biome ci --max-diagnostics=none --error-on-warnings"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/20minutes/s3-unzip-plus.git"
  },
  "author": "20 Minutes",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1081.0",
    "@aws-sdk/lib-storage": "^3.1081.0",
    "adm-zip": "^0.5.18",
    "cleye": "^2.6.0",
    "mime-types": "^3.0.2"
  },
  "devDependencies": {
    "@20minutes/eslint-config": "^3.0.4",
    "@smithy/util-stream": "^4.7.6",
    "@types/adm-zip": "^0.5.8",
    "@types/jest": "^30.0.0",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^26.1.1",
    "aws-sdk-client-mock": "^4.1.0",
    "aws-sdk-client-mock-jest": "^4.1.0",
    "es-check": "^9.6.4",
    "jest": "^30.4.2",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3"
  },
  "types": "lib/index.d.ts"
}
